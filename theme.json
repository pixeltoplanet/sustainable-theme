{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"defaultDuotone": true,
			"defaultGradients": true,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Background",
					"slug": "background"
				},
				{
					"color": "#000000",
					"name": "Foreground",
					"slug": "foreground"
				},
				{
					"color": "#D8D8D8",
					"name": "Neutral 1",
					"slug": "neutral-1"
				},
				{
					"color": "#7F7F7F",
					"name": "Neutral 2",
					"slug": "neutral-2"
				},
				{
					"color": "#00FF00",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#0000DB",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#FF6600",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#FFFF00",
					"name": "Accent",
					"slug": "accent"
				}
			]
		},
		"layout": {
			"contentSize": "900px",
			"wideSize": "1300px",
			"allowCustomContentAndWideSize": true
		},
		"custom": {
			"spacingScale": 1,
			"rounded": {
				"card": "15px",
				"image": "15px",
				"button": "4px"
			},
			"size": {
				"px": "1px",
				"0-5": "0.125rem",
				"1": "0.25rem",
				"1-5": "0.375rem",
				"2": "0.5rem",
				"2-5": "0.625rem",
				"3": "0.75rem",
				"3-5": "0.875rem",
				"4": "1rem",
				"5": "1.25rem",
				"6": "1.5rem",
				"7": "1.75rem",
				"8": "2rem",
				"9": "2.25rem",
				"10": "2.5rem",
				"11": "2.75rem",
				"12": "3rem",
				"14": "3.5rem",
				"16": "4rem",
				"20": "5rem",
				"24": "6rem",
				"28": "7rem",
				"32": "8rem",
				"36": "9rem",
				"40": "10rem",
				"44": "11rem",
				"48": "12rem",
				"52": "13rem",
				"56": "14rem",
				"60": "15rem",
				"64": "16rem",
				"72": "18rem",
				"80": "20rem",
				"96": "24rem"
			}
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 8,
				"mediumStep": 1.5,
				"unit": "rem"
			},
			"spacingSizes": [
				{
					"name": "Fluid X-Small",
					"size": "clamp(0.25rem, 1.5vw, 0.5rem)",
					"slug": "fluid-x-small"
				},
				{
					"name": "Fluid Small",
					"size": "clamp(1rem, 3vw, 1.5rem)",
					"slug": "fluid-small"
				},
				{
					"name": "Fluid Medium",
					"size": "clamp(1.5rem, 4.5vw, 5rem)",
					"slug": "fluid-medium"
				},
				{
					"name": "Fluid Large",
					"size": "clamp(2rem, 5vw, 6rem)",
					"slug": "fluid-large"
				},
				{
					"name": "Fluid X-Large",
					"size": "clamp(4rem, 8vw, 10rem)",
					"slug": "fluid-x-large"
				}
			],
			"units": ["%", "px", "rem", "vh", "vw"]
		},
		"typography": {
			"customFontSize": false,
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": true,
			"dropCap": false,
			"fontSizes": [
				{
					"name": "XS - credits / captions",
					"size": "0.8em",
					"slug": "xs",
					"fluid": {
						"min": "0.75rem",
						"max": "0.85rem"
					}
				},
				{
					"name": "SM - small copy",
					"size": "0.9em",
					"slug": "sm",
					"fluid": {
						"min": "0.9rem",
						"max": "1rem"
					}
				},
				{
					"name": "MD - body text",
					"size": "1.1rem",
					"slug": "md",
					"fluid": {
						"min": "1rem",
						"max": "1.2rem"
					}
				},
				{
					"name": "LG - intros / quotes",
					"size": "1.5rem",
					"slug": "lg",
					"fluid": {
						"min": "1.4rem",
						"max": "1.6rem"
					}
				},
				{
					"name": "XL - subtitles",
					"size": "2.5rem",
					"slug": "xl",
					"fluid": {
						"min": "2.5rem",
						"max": "2.5rem"
					}
				},
				{
					"name": "2XL - headings",
					"size": "4rem",
					"slug": "xxl",
					"fluid": {
						"min": "2.5rem",
						"max": "3.7rem"
					}
				},
				{
					"name": "3XL - titles",
					"size": "7rem",
					"slug": "xxxl",
					"fluid": {
						"min": "3rem",
						"max": "7rem"
					}
				}
			],

			"lineHeight": true,
			"textColumns": false,
			"fontFamilies": [
				{
					"name": "DM Sans",
					"slug": "dm-sans",
					"fontFamily": "DM Sans, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/dm-sans/DMSans-VariableFont_opsz,wght.ttf"
							],
							"fontWeight": "200 800",
							"fontStyle": "normal",
							"fontFamily": "DM Sans"
						}
					]
				}
			],
			"fontStyle": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|background",
			"text": "var:preset|color|foreground"
		},
		"spacing": {
			"padding": {
				"left": "var:preset|spacing|fluid-small",
				"right": "var:preset|spacing|fluid-small"
			},
			"blockGap": "0px"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|dm-sans",
			"fontSize": "var:preset|font-size|md",
			"fontWeight": "400",
			"letterSpacing": "0",
			"lineHeight": "1.3",
			"color": {
				"text": "var:preset|color|foreground"
			}
		},
		"blocks": {
			"core/image": {
				"lightbox": {
					"allowEditing": true
				}
			},
			"core/group": {
				"spacing": {
					"defaultSpacingSizes": false,
					"customSpacingSize": false,
					"spacingSizes": [
						{
							"name": "Section",
							"size": "clamp(1.5rem, 4.5vw, 6rem)",
							"slug": "section"
						}
					]
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "currentColor",
							"width": "1px"
						},
						"css": ".wp-block-button__link:not(.has-background):hover {background-color:color-mix(in srgb, var(--wp--preset--color--foreground) 5%, transparent);}"
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "var:preset|spacing|fluid-small"
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var:preset|spacing|fluid-x-small"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var:preset|font-family|fira-code",
					"fontSize": "var:preset|font-size|md",
					"fontWeight": "300"
				},
				"color": {
					"background": "var:preset|color|neutral-1",
					"text": "var:preset|color|foreground"
				},
				"spacing": {
					"padding": {
						"right": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40",
						"left": "var:preset|spacing|40",
						"top": "var:preset|spacing|40"
					}
				}
			},
			"core/comment-author-name": {
				"color": {
					"text": "var:preset|color|neutral-2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs"
				},
				"spacing": {
					"margin": {
						"top": "5px",
						"bottom": "0px"
					}
				}
			},
			"core/comment-content": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				},
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|30",
						"bottom": "var:preset|spacing|30"
					}
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "var:preset|font-size|xs"
				},
				"color": {
					"text": "var:preset|color|neutral-2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary"
						}
					}
				}
			},
			"core/comment-edit-link": {
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary"
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs"
				}
			},
			"core/comment-reply-link": {
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary"
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs"
				}
			},
			"core/post-comments-form": {
				"css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--foreground) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--xs); }",
				"typography": {
					"fontSize": "var:preset|font-size|md"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40"
					}
				}
			},
			"core/comments-pagination": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				},
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40"
					}
				}
			},
			"core/comments-pagination-next": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"core/comments-pagination-numbers": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"core/comments-pagination-previous": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"core/post-date": {
				"color": {
					"text": "var:preset|color|neutral-2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|xs"
				}
			},
			"core/post-navigation-link": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"core/post-terms": {
				"css": "& a { white-space: nowrap; }",
				"typography": {
					"fontSize": "var:preset|font-size|xs",
					"fontWeight": "600"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/quote": {
				"border": {
					"style": "solid",
					"width": "0 0 0 2px",
					"color": "currentColor"
				},
				"spacing": {
					"blockGap": "var:preset|spacing|30",
					"margin": {
						"left": "0",
						"right": "0"
					},
					"padding": {
						"top": "var:preset|spacing|30",
						"right": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|30",
						"left": "var:preset|spacing|40"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"fontWeight": "300"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var:preset|font-size|xs",
							"fontStyle": "normal",
							"fontWeight": "300"
						},
						"css": "& sub { font-size: 0.65em }"
					}
				},
				"css": "&.has-text-align-right { border-width: 0 2px 0 0; } &.has-text-align-center { border-width: 0;border-inline: 0; padding-inline: 0; }",
				"variations": {
					"plain": {
						"border": {
							"color": "transparent",
							"style": "none",
							"width": "0",
							"radius": "0"
						},
						"spacing": {
							"padding": {
								"top": "0",
								"right": "0",
								"bottom": "0",
								"left": "0"
							}
						}
					}
				}
			},
			"core/pullquote": {
				"typography": {
					"fontSize": "var:preset|font-size|2xl",
					"fontWeight": "300",
					"lineHeight": "1.2"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var:preset|font-size|xs",
							"fontStyle": "normal"
						}
					}
				},
				"spacing": {
					"padding": {
						"bottom": "var:preset|spacing|30",
						"top": "var:preset|spacing|30"
					}
				},
				"css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--30);}"
			},
			"core/query-pagination": {
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"fontWeight": "500"
				}
			},
			"core/search": {
				"css": "& .wp-block-search__input{border-radius:3.125rem;padding-left:1.5625rem;padding-right:1.5625rem;border-color:var(--wp--preset--color--foreground);}",
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"lineHeight": "1.6"
				},
				"elements": {
					"button": {
						"border": {
							"radius": "3.125rem"
						},
						"spacing": {
							"margin": {
								"left": "1.125rem"
							}
						},
						":hover": {
							"border": {
								"color": "transparent"
							}
						}
					}
				}
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"style": "solid",
					"width": "0 0 1px 0"
				},
				"color": {
					"text": "var:preset|color|neutral-1"
				},
				"variations": {
					"wide": {
						"css": " &:not(.alignfull){max-width: var(--wp--style--global--wide-size) !important;}"
					}
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"core/site-title": {
				"typography": {
					"fontSize": "var:preset|font-size|sm"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/term-description": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				},
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/list": {
				"css": "& li{margin-top: 0.5rem;}"
			}
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|secondary",
					"text": "var:preset|color|background",
					"border": {
						"color": "var:preset|color|secondary",
						"width": "1px",
						"radius": "var(--rounded-button)"
					}
				},
				":focus": {
					"outline": {
						"color": "var:preset|color|secondary",
						"offset": "2px"
					}
				},
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--secondary) 85%, transparent)",
						"text": "var:preset|color|background"
					},
					"border": {
						"color": "var:preset|color|secondary"
					}
				},

				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var:preset|font-size|xs",
					"lineHeight": "1.4"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xxl",
					"lineHeight": "0.9"
				},
				"color": {
					"text": "var:preset|color|foreground"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|xxl",
					"lineHeight": "0.9"
				},
				"color": {
					"text": "var:preset|color|foreground"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"lineHeight": "1"
				},
				"color": {
					"text": "var:preset|color|foreground"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"lineHeight": "1"
				},
				"color": {
					"text": "var:preset|color|foreground"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var:preset|color|foreground"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"lineHeight": "1.2"
				}
			},
			"heading": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"fontWeight": "700",
					"lineHeight": "1"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				},
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "uncategorized",
			"name": "single-post-hero",
			"title": "Single post hero"
		},
		{
			"area": "uncategorized",
			"name": "single-post-related",
			"title": "Single post related"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"postTypes": ["page"],
			"title": "Page No Title"
		}
	]
}
