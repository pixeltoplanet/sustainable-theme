{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#E8F5E9",
					"name": "Primary Background",
					"slug": "primary-background"
				},
				{
					"color": "#2E7D32",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#1B5E20",
					"name": "Primary Foreground",
					"slug": "primary-foreground"
				},
				{
					"color": "#FFF3E0",
					"name": "Secondary Background",
					"slug": "secondary-background"
				},
				{
					"color": "#E65100",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#BF360C",
					"name": "Secondary Foreground",
					"slug": "secondary-foreground"
				},
				{
					"color": "#E3F2FD",
					"name": "Tertiary Background",
					"slug": "tertiary-background"
				},
				{
					"color": "#1976D2",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#0D47A1",
					"name": "Tertiary Foreground",
					"slug": "tertiary-foreground"
				},
				{
					"color": "#FFFFFF",
					"name": "Background",
					"slug": "background"
				},
				{
					"color": "#000000",
					"name": "Foreground",
					"slug": "foreground"
				},
				{
					"color": "#9E9E9E",
					"name": "muted",
					"slug": "muted"
				},
				{
					"color": "#F5F5F5",
					"name": "Neutral background",
					"slug": "neutral-background"
				},
				{
					"color": "#757575",
					"name": "Neutral",
					"slug": "neutral"
				},
				{
					"color": "#212121",
					"name": "Neutral foreground",
					"slug": "neutral-foreground"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "black"
				},
				{
					"color": "#FFFFFF",
					"name": "White",
					"slug": "white"
				}
			]
		},
		"layout": {
			"contentSize": "900px",
			"wideSize": "1340px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "xs",
					"size": "var(--spacing-xs)",
					"slug": "xs"
				},
				{
					"name": "sm",
					"size": "var(--spacing-sm)",
					"slug": "sm"
				},
				{
					"name": "md",
					"size": "var(--spacing-md)",
					"slug": "md"
				},
				{
					"name": "lg",
					"size": "var(--spacing-lg)",
					"slug": "lg"
				},
				{
					"name": "xl",
					"size": "var(--spacing-xl)",
					"slug": "xl"
				},
				{
					"name": "2xl",
					"size": "var(--spacing-2xl)",
					"slug": "2xl"
				},
				{
					"name": "3xl",
					"size": "var(--spacing-3xl)",
					"slug": "3xl"
				},
				{
					"name": "4xl",
					"size": "var(--spacing-4xl)",
					"slug": "4xl"
				},
				{
					"name": "5xl",
					"size": "var(--spacing-5xl)",
					"slug": "5xl"
				},
				{
					"name": "6xl",
					"size": "var(--spacing-6xl)",
					"slug": "6xl"
				}
			],
			"units": ["%", "px", "em", "rem", "vh", "vw"]
		},
		"typography": {
			"customFontSize": false,
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": false,
			"dropCap": false,
			"fontSizes": [
				{
					"name": "Small copy",
					"size": "0.8rem",
					"fluid": {
						"min": "0.5rem",
						"max": "0.9rem"
					},
					"slug": "sm"
				},
				{
					"name": "Body text",
					"size": "1rem",
					"slug": "md"
				},
				{
					"name": "Intro and large body text",
					"size": "1.5rem",
					"slug": "lg"
				},
				{
					"name": "Heading",
					"size": "2rem",
					"slug": "xl"
				},
				{
					"name": "Large heading",
					"size": "3rem",
					"slug": "2xl"
				},
				{
					"name": "Hero / marketing headings",
					"size": "3.5rem",
					"slug": "3xl"
				}
			],
			"fontStyle": true
		},
		"useRootPaddingAwareAlignments": false
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"postTypes": ["page"],
			"title": "Page No Title"
		}
	]
}
